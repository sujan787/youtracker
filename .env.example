# ──────────────────────────────────────────────────────────────────────────
# YouMark — environment variables
# Copy this file to `.env` and fill in the real values.
#   cp .env.example .env
# `.env` is git-ignored; never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────
# Public base URL of the app (used in verification email links).
APP_URL=http://localhost:3000

# ── NextAuth ───────────────────────────────────────────────────────────────
# The canonical URL of your site (no trailing slash). Use the deployed URL in prod.
NEXTAUTH_URL=http://localhost:3000
# Secret used to encrypt the JWT session cookie. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Connection string for postgres-js / drizzle.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/youmark

# ── Google OAuth ───────────────────────────────────────────────────────────
# Create an OAuth 2.0 Client (type: Web application) at
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email verification tokens (jsonwebtoken) ───────────────────────────────
# Secret used to sign email-verification / reset tokens. Generate with:
#   openssl rand -base64 32
JWT_SECRET=replace-with-output-of-openssl-rand-base64-32

# ── Mail (Gmail SMTP via nodemailer) ───────────────────────────────────────
# The Gmail account used to send mail and a Gmail "App Password"
# (https://myaccount.google.com/apppasswords), NOT your normal password.
MAIL_ID=your-gmail-address@gmail.com
MAIL_PASSWORD=your-16-char-gmail-app-password
# The "From" address shown on outgoing mail (usually the same as MAIL_ID).
EMAIL_SERVER_USER=your-gmail-address@gmail.com

# ── YouTube Data API v3 ────────────────────────────────────────────────────
# API key from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_API_KEY=your-youtube-data-api-key
